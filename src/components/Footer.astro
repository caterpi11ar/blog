---
import { cn } from '@utils/cn'
import Hr from './Hr.astro'
import Socials from './Socials/index.astro'

const currentYear = new Date().getFullYear()

export interface Props {
  noMarginTop?: boolean
}

const { noMarginTop = false } = Astro.props
---

<footer class={cn('w-full', !noMarginTop && 'mt-auto')}>
  <Hr noPadding />
  <div class="flex flex-col items-center justify-between py-6 sm:flex-row-reverse sm:py-4">
    <Socials centered />
    <div class="my-2 flex flex-col items-center whitespace-nowrap sm:flex-row">
      <a
        href="https://caterpi11ar.com/"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-1 hover:text-[#006cac] transition-colors"
      >
        <img
          src="https://raw.githubusercontent.com/caterpi11ar/assets/main/logo/caterpi11ar.jpg"
          alt="caterpi11ar"
          width="20"
          height="20"
          class="rounded-full"
        />
        caterpi11ar
      </a>
      <span class="hidden sm:inline">&nbsp;|&nbsp;</span>
      <span>Copyright &#169; {currentYear}</span>
      <span class="hidden sm:inline">&nbsp;|&nbsp;</span>
      <span>蒙ICP备2025022309号-3</span>
    </div>
  </div>
</footer>
